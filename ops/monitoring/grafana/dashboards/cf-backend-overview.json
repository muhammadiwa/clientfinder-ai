{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "ClientFinder AI Agent — backend metrics overview. T8.5 Group 2.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Request rate (per second, per path)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      },
      "targets": [
        {
          "expr": "sum by (path) (rate(cf_http_requests_total[1m]))",
          "legendFormat": "{{ path }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error rate (% 5xx of total)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.05},
              {"color": "red", "value": 0.20}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(cf_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(cf_http_requests_total[5m]))",
          "legendFormat": "5xx rate",
          "refId": "A"
        }
      ]
    },
    {
      "title": "P95 latency (per path, seconds)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"lineWidth": 2}
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(cf_http_request_duration_seconds_bucket[5m])) by (path, le))",
          "legendFormat": "{{ path }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Rate limit hits (per minute, by path)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2, "fillOpacity": 20}
        }
      },
      "targets": [
        {
          "expr": "sum by (path) (increase(cf_rate_limit_hits_total[1m]))",
          "legendFormat": "{{ path }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Service health (db + redis)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "gridPos": {"h": 4, "w": 12, "x": 0, "y": 16},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "targets": [
        {"expr": "cf_db_up", "legendFormat": "PostgreSQL", "refId": "A"},
        {"expr": "cf_redis_up", "legendFormat": "Redis", "refId": "B"}
      ]
    },
    {
      "title": "In-progress requests",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 16},
      "fieldConfig": {
        "defaults": {"unit": "short"}
      },
      "targets": [
        {
          "expr": "sum by (method) (cf_http_requests_in_progress)",
          "legendFormat": "{{ method }}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["clientfinder", "production"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
