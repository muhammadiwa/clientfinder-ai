# =============================================================
# ClientFinder AI Agent — Environment Variables
# =============================================================
# Copy file ini ke .env lalu isi semua value
# Generate secret dengan: openssl rand -hex 32

# ---------- App ----------
APP_ENV=local
APP_NAME=ClientFinder
APP_VERSION=0.1.0
APP_DEBUG=true
APP_SECRET=change-me-with-openssl-rand-hex-32
APP_TIMEZONE=Asia/Jakarta
APP_BASE_URL=http://localhost

# ---------- Backend ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=2
BACKEND_LOG_LEVEL=info
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# ---------- Frontend ----------
FRONTEND_PORT=5173
VITE_API_URL=/api/v1

# ---------- PostgreSQL ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=clientfinder
POSTGRES_USER=clientfinder
POSTGRES_PASSWORD=change-me-strong-db-password

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# ---------- MinIO ----------
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=clientfinder
MINIO_ROOT_PASSWORD=change-me-strong-minio-password
MINIO_BUCKET_PROSPECTS=prospects
MINIO_BUCKET_SCREENSHOTS=screenshots
MINIO_BUCKET_RAW=raw-data
MINIO_USE_SSL=false

# ---------- SearXNG (Scout Module: Google) ----------
# Reuses existing searxng instance running on host. Set to container DNS
# if running in our compose, or to host.docker.internal:PORT for external.
SEARXNG_BASE_URL=http://host.docker.internal:8888
SEARXNG_SECRET=change-me-searxng-secret

# ---------- Nginx ----------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_CLIENT_MAX_BODY_SIZE=20M

# ---------- Celery / Flower ----------
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=540
FLOWER_PORT=5555
FLOWER_USER=admin
FLOWER_PASSWORD=change-me-flower-password

# ---------- LLM (free tier) ----------
LLM_PRIMARY_PROVIDER=groq
LLM_PRIMARY_MODEL=llama-3.1-70b-versatile
LLM_PRIMARY_API_KEY=your-groq-api-key
LLM_FALLBACK_PROVIDER=gemini
LLM_FALLBACK_MODEL=gemini-1.5-flash
LLM_FALLBACK_API_KEY=your-gemini-api-key
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ---------- Email (Outbound) ----------
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=outreach@yourdomain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=ClientFinder
SMTP_FROM_EMAIL=outreach@yourdomain.com
SMTP_USE_TLS=true
SMTP_DAILY_LIMIT=100

# ---------- WhatsApp (WAHA) ----------
WAHA_BASE_URL=http://waha:3000
WAHA_SESSION_NAME=default
WAHA_API_KEY=your-waha-api-key

# ---------- Threads (Playwright cookies) ----------
THREADS_COOKIES_PATH=/app/.sessions/threads_cookies.json
THREADS_DAILY_DM_LIMIT=20

# ---------- Scraping ----------
SCRAPER_USER_AGENT_ROTATION=true
SCRAPER_REQUEST_DELAY_MIN=3
SCRAPER_REQUEST_DELAY_MAX=8
SCRAPER_MAX_CONCURRENT=2
SCRAPER_PROXY_ENABLED=false
SCRAPER_PROXY_LIST=

# ---------- Outreach ----------
OUTREACH_AUTO_APPROVE=false
OUTREACH_DEFAULT_TIMEZONE=Asia/Jakarta
OUTREACH_BUSINESS_HOURS_START=09:00
OUTREACH_BUSINESS_HOURS_END=18:00

# ---------- Monitoring ----------
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# ---------- Backup ----------
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PASSPHRASE=change-me-backup-encryption
BACKUP_REMOTE_TARGET=

# ---------- Feature flags ----------
FEATURE_SCOUT_GOOGLE=true
FEATURE_SCOUT_MAPS=true
FEATURE_SCOUT_TWITTER=true
FEATURE_SCOUT_THREADS=true
FEATURE_OUTREACH_EMAIL=true
FEATURE_OUTREACH_WHATSAPP=true
FEATURE_OUTREACH_THREADS=true
FEATURE_AUTO_ENRICH=true
FEATURE_AUTO_SCORE=true
FEATURE_AUTO_HOOKS=true
